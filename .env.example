# PostgreSQL connection string
# For local development: postgresql://user:password@localhost:5432/issue_tracker
# For Neon/Supabase: use the pooled connection string
DATABASE_URL="postgresql://user:password@localhost:5432/issue_tracker?schema=public"

# JWT signing secret — must be at least 32 characters
# Generate a strong key: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
